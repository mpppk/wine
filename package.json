{
	"name": "wine",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"preview": "bun run build && vite preview",
		"test": "vitest run",
		"format": "biome format",
		"lint": "biome lint",
		"check": "biome check",
		"typecheck": "tsc",
		"smoke": "bash scripts/smoke.sh",
		"deploy": "bun run build && wrangler deploy",
		"deploy:preview": "CLOUDFLARE_ENV=preview vite build && CLOUDFLARE_ENV=preview wrangler versions upload",
		"build:geodata": "node scripts/build-aop-geodata.mjs",
		"build:geodata:italy": "node scripts/build-italy-geodata.mjs",
		"build:centroids": "node scripts/build-aop-centroids.mjs",
		"build:boundaries": "bun scripts/build-region-boundaries.mjs",
		"db:migrate:local": "wrangler d1 migrations apply DB --local",
		"db:migrate:remote": "wrangler d1 migrations apply DB --remote",
		"db:migrate:preview": "wrangler d1 migrations apply DB --remote --env preview",
		"cf-typegen": "wrangler types"
	},
	"dependencies": {
		"@better-auth/stripe": "^1.6.23",
		"@cloudflare/vite-plugin": "^1.45.0",
		"@mcp-ui/server": "^6.1.0",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@radix-ui/react-checkbox": "^1.3.3",
		"@radix-ui/react-dialog": "^1.1.17",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-switch": "^1.2.6",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/react-devtools": "^0.10.2",
		"@tanstack/react-query": "^5.100.9",
		"@tanstack/react-query-devtools": "^5.100.9",
		"@tanstack/react-router": "^1.169.2",
		"@tanstack/react-router-devtools": "^1.166.13",
		"@tanstack/react-router-ssr-query": "^1.166.12",
		"@tanstack/react-start": "^1.167.65",
		"@tanstack/router-plugin": "^1.167.35",
		"better-auth": "^1.6.14",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"drizzle-orm": "^0.45.1",
		"lucide-react": "^1.0.0",
		"maplibre-gl": "^5.24.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"stripe": "^22.3.1",
		"tailwind-merge": "^3.0.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.3.6",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.4",
		"@tailwindcss/typography": "^0.5.16",
		"@tanstack/devtools-vite": "^0.6.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.0",
		"@types/node": "^26.0.0",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^6.0.1",
		"jsdom": "^29.0.0",
		"mapshaper": "^0.7.39",
		"tsx": "^4.21.0",
		"typescript": "^7.0.0",
		"vite": "^8.0.0",

BETTER_AUTH_URL=http://localhost:3000

# better-auth のセッションCookie署名・OAuthトークン生成に使う必須シークレット。
# 本番/プレビューは `wrangler secret put BETTER_AUTH_SECRET` で投入する。ローカルは
# 任意のランダム文字列でよい(例: `bunx --bun @better-auth/cli secret` で生成)。
BETTER_AUTH_SECRET=

# アフィリエイトID(任意)。未設定なら購入リンクは素の検索URLになる。
# RAKUTEN_AFFILIATE_ID=0a1b2c3d.e4f5a6b7.0a1b2c3d.e4f5a6b8
# MOSHIMO_AMAZON_A_ID=1234567
RAKUTEN_AFFILIATE_ID=
MOSHIMO_AMAZON_A_ID=

# Stripe(任意)。未設定でもアプリは動作し、料金ページの購入ボタンが無効化される。
# STRIPE_SECRET_KEY はテストモードのシークレットキー(sk_test_...)を設定する。
# STRIPE_WEBHOOK_SECRET は `stripe listen --forward-to http://localhost:3000/api/auth/stripe/webhook`
# が表示する whsec_... を設定する。
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=

# 既存プレミアム会員の「期間延長」キャンペーンコード(任意)。"CODE=延長日数" を
# カンマ区切りで指定する。会員が profile ページで入力すると契約期間が延長される。
# 例: CAMPAIGN_EXTENSION_CODES=WINE7=7,SUMMER=14
CAMPAIGN_EXTENSION_CODES=
